name: Lorie CI

on:
  workflow_dispatch:
  push:
    branches:
      - lorie-ci

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Clone repository
        uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 1

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: temurin
          cache: gradle

      - name: Grant execute permission for gradlew
        run: chmod +x gradlew

      - name: Fetch and checkout Lorie branch
        run: |
          git remote remove apathiaxplavil 2>/dev/null || true
          git remote add apathiaxplavil https://github.com/apathiaxplavil/winlator.git
          git fetch --no-tags --depth=1 apathiaxplavil Xlorie
          git checkout -B lorie-build apathiaxplavil/Xlorie

      - name: Sync submodules
        run: |
          git submodule sync --recursive
          git submodule update --init --recursive

      - name: Build with Gradle
        run: ./gradlew assembleDebug

      - name: Get Short SHA
        run: echo "SHORT_SHA=$(git rev-parse --short HEAD)" >> $GITHUB_ENV

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: lorie-test-${{ env.SHORT_SHA }}
          path: app/build/outputs/apk/debug/app-debug.apk
