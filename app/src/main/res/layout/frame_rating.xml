<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="6dp">

    <!-- FPS Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/TVFPSLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS: "
            android:textColor="#00E676"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/TVFPS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0"
            android:textColor="#00E676"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Renderer Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API: "
            android:textColor="#42A5F5"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/TVRenderer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OpenGL"
            android:textColor="#42A5F5"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- GPU Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPU: "
            android:textColor="#AB47BC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/TVGPU"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AB47BC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/TVGPUUsage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#AB47BC"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- CPU Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU: "
            android:textColor="#FF7043"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/TVCPU"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF7043"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- CPU Usage Row -->
    <TextView
        android:id="@+id/TVCPUUsage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#00E676"
        android:textSize="10sp" />

    <!-- RAM Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAM: "
            android:textColor="#26C6DA"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/TVRAM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#26C6DA"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>

