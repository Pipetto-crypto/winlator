<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:gravity="center_horizontal"
    android:layout_gravity="center_horizontal"
    android:background="@drawable/frame_rating_round_corners">

    <LinearLayout
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:id="@+id/TVRenderer"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#A12650"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="85dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:text="CPU:"
            android:textColor="#AB9231"
            android:includeFontPadding="false"
            android:maxLines="1" />

        <TextView
            android:id="@+id/TVCPU"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#ffffff"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="85dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:text="RAM:"
            android:textColor="#43B7EA"
            android:includeFontPadding="false"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/TVRAM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#ffffff"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="85dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:text="TMP:"
            android:textColor="#BB2F39"
            android:includeFontPadding="false"
            android:maxLines="1" />

        <TextView
            android:id="@+id/TVTMP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#ffffff"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>
    
    <LinearLayout
        android:layout_width="105dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:text="POW:"
            android:textColor="#734797"
            android:includeFontPadding="false"
            android:maxLines="1" />

        <TextView
            android:id="@+id/TVPOWER"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#ffffff"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:text="FPS:"
            android:textColor="#DFEF5D"
            android:includeFontPadding="false"
            android:maxLines="1" />

        <TextView
            android:id="@+id/TVFPS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#ffffff"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="35dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|left">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/TVTIME"
            android:textStyle="bold"
            android:textSize="13dp"
            android:textColor="#72EC11"
            android:includeFontPadding="false"
            android:maxLines="1" />
    </LinearLayout>
</LinearLayout>